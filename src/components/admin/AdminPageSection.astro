---
interface Props {
  pageTitleMaxLength: number;
  pageSubtitleMaxLength: number;
  memoTitlePlaceholder?: string;
  memoSubtitlePlaceholder?: string;
}

const {
  pageTitleMaxLength,
  pageSubtitleMaxLength,
  memoTitlePlaceholder = '',
  memoSubtitlePlaceholder = ''
} = Astro.props;
---

<fieldset class="admin-group">
  <legend class="admin-group__legend">
    <span class="admin-group__legend-zh">内页设置</span>
    <span class="admin-group__legend-sep" aria-hidden="true">·</span>
    <span class="admin-group__legend-en">Inner pages</span>
  </legend>
  <div class="admin-grid">
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/essay/</code> 页面主 <span class="admin-label__pipe" aria-hidden="true">|</span> 副标题
        </span>
        <span class="admin-label__hint">（动态计数 / RSS 固定输出）</span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/essay/ 页面主标题与副标题">
        <input
          id="page-essay-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="随笔"
          aria-label="/essay/ 页面主标题"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-essay-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="随笔与杂记"
          aria-label="/essay/ 页面副标题"
        />
      </span>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/bits/</code> 页面主 <span class="admin-label__pipe" aria-hidden="true">|</span> 副标题
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/bits/ 页面主标题与副标题">
        <input
          id="page-bits-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="絮语"
          aria-label="/bits/ 页面主标题"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-bits-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="生活不只是长篇"
          aria-label="/bits/ 页面副标题"
        />
      </span>
    </label>
    <label class="admin-field admin-field--full admin-field--memo">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/memo/</code> 页面主 <span class="admin-label__pipe" aria-hidden="true">|</span> 副标题
        </span>
        <span class="admin-label__hint">（填写后覆盖对应字段，留空则沿用 src/content/memo/index.md）</span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/memo/ 页面主标题与副标题">
        <input
          id="page-memo-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder={memoTitlePlaceholder || undefined}
          aria-label="/memo/ 页面主标题"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-memo-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder={memoSubtitlePlaceholder || undefined}
          aria-label="/memo/ 页面副标题"
        />
      </span>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/archive/</code> 页面主 <span class="admin-label__pipe" aria-hidden="true">|</span> 副标题
        </span>
        <span class="admin-label__hint">（动态计数 / RSS 固定输出）</span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/archive/ 页面主标题与副标题">
        <input
          id="page-archive-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="归档"
          aria-label="/archive/ 页面主标题"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-archive-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="按年份分组的归档目录"
          aria-label="/archive/ 页面副标题"
        />
      </span>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/about/</code> 页面主 <span class="admin-label__pipe" aria-hidden="true">|</span> 副标题
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/about/ 页面主标题与副标题">
        <input
          id="page-about-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="关于"
          aria-label="/about/ 页面主标题"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-about-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          aria-label="/about/ 页面副标题"
        />
      </span>
    </label>
  </div>

  <div class="admin-subgroup">
    <p class="admin-subtitle">
      <span class="admin-subtitle__main">/bits/页默认作者</span>
    </p>
    <div class="admin-grid">
      <label class="admin-field">
        <span class="admin-label">
          <span class="admin-label__main">默认作者名</span>
        </span>
        <input id="page-bits-author-name" type="text" autocomplete="off" />
      </label>
      <label class="admin-field">
        <span class="admin-label">
          <span class="admin-label__main">默认头像</span>
          <span class="admin-label__hint">（相对路径）</span>
        </span>
        <input id="page-bits-author-avatar" type="text" autocomplete="off" />
      </label>
    </div>
  </div>
</fieldset>
