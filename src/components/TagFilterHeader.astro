---
import Icon from './Icon.astro';

type TagOption = {
  count: number;
  href: string;
  isActive?: boolean;
  key: string;
  label: string;
};

type CurrentTagState = {
  clearHref: string;
  label: string;
};

const {
  currentTag = null,
  dialogTitleId,
  fallbackListId,
  headerClass = 'page-header page-header--with-search',
  pageTitleText,
  pickerHref,
  rssHref,
  searchAriaLabel,
  subtitleText = null,
  tagOptions = []
} = Astro.props as {
  currentTag?: CurrentTagState | null;
  dialogTitleId: string;
  fallbackListId: string;
  headerClass?: string;
  pageTitleText: string;
  pickerHref: string;
  rssHref: string;
  searchAriaLabel: string;
  subtitleText?: string | null;
  tagOptions?: TagOption[];
};

const hasTagEntry = tagOptions.length > 0;
---

<div class={headerClass}>
  <div class="page-heading">
    <h1 class="page-title">{pageTitleText}</h1>
    <span class="page-subtitle page-subtitle--entry-filters">
      {subtitleText ? <span class="page-subtitle__text">{subtitleText}</span> : null}
      <a class="page-subtitle__link page-subtitle__item" href={rssHref}>RSS</a>
      {hasTagEntry ? (
        <a
          class="page-subtitle__action page-subtitle__item"
          href={pickerHref}
          data-entry-tag-trigger
          aria-haspopup="dialog"
          aria-expanded="false"
        >
          #标签
        </a>
      ) : null}
    </span>
  </div>
  <div class="page-actions">
    <div class="entry-search" data-entry-search>
      <div class="entry-search-panel" data-entry-search-panel aria-hidden="true">
        <input
          data-entry-search-input
          type="search"
          placeholder="搜索：标题 / 摘要 / 标签"
          autocomplete="off"
          aria-label={searchAriaLabel}
        />
      </div>
      <button
        class="entry-search-toggle"
        data-entry-search-toggle
        type="button"
        aria-label={searchAriaLabel}
        title="搜索"
        aria-expanded="false"
      >
        <Icon name="search" class="icon" />
      </button>
    </div>
  </div>
</div>

{currentTag ? (
  <div class="entry-tag-current">
    <span class="entry-tag-current__pill">
      <span>标签</span>
      <strong>#{currentTag.label}</strong>
    </span>
    <a class="entry-tag-current__clear" href={currentTag.clearHref}>清除</a>
  </div>
) : null}

<div class="entry-status" data-entry-search-status role="status" aria-live="polite"></div>

{hasTagEntry ? (
  <>
    <dialog class="entry-tags-dialog" data-entry-tag-dialog aria-labelledby={dialogTitleId}>
      <div class="entry-tags-dialog__inner">
        <div class="entry-tags-dialog__handle" aria-hidden="true"></div>
        <div class="entry-tags-dialog__head">
          <div class="entry-tags-dialog__title-wrap">
            <div class="entry-tags-dialog__title-row">
              <h2 class="entry-tags-dialog__title" id={dialogTitleId} tabindex="-1">{pageTitleText}标签</h2>
              <p class="entry-tags-dialog__hint">共 {tagOptions.length} 个</p>
            </div>
          </div>
          <div class="entry-tags-dialog__actions">
            <button class="entry-tags-dialog__close" type="button" data-entry-tag-close aria-label="关闭标签选择器">
              ✕
            </button>
          </div>
        </div>
        <div class="entry-tags-dialog__list">
          {tagOptions.map((tagOption) => (
            <a
              class:list={['entry-tag-option', tagOption.isActive && 'is-active']}
              href={tagOption.href}
              data-entry-tag-key={tagOption.key}
              aria-current={tagOption.isActive ? 'page' : undefined}
            >
              <span class="entry-tag-option__label">#{tagOption.label}</span>
              <span class="entry-tag-option__count">{tagOption.count}</span>
            </a>
          ))}
        </div>
      </div>
    </dialog>
    <noscript>
      <section class="entry-tags-fallback" id={fallbackListId} aria-labelledby={`${dialogTitleId}-fallback`}>
        <div class="entry-tags-fallback__head">
          <h2 class="entry-tags-fallback__title" id={`${dialogTitleId}-fallback`}>{pageTitleText}标签</h2>
          <p class="entry-tags-fallback__hint">
            当前为无 JavaScript 模式，可直接点击下列标签进入静态结果页。
          </p>
        </div>
        <div class="entry-tags-dialog__toolbar">
          <span class="entry-tags-dialog__summary">共 {tagOptions.length} 个标签，可直接访问结果页。</span>
          {currentTag ? (
            <a class="entry-tags-dialog__clear" href={currentTag.clearHref}>查看全部</a>
          ) : (
            <span class="entry-tags-dialog__summary entry-tags-dialog__summary--secondary">下列标签链接可直接访问结果页</span>
          )}
        </div>
        <div class="entry-tags-dialog__list">
          {tagOptions.map((tagOption) => (
            <a
              class:list={['entry-tag-option', tagOption.isActive && 'is-active']}
              href={tagOption.href}
              aria-current={tagOption.isActive ? 'page' : undefined}
            >
              <span class="entry-tag-option__label">#{tagOption.label}</span>
              <span class="entry-tag-option__count">{tagOption.count}</span>
            </a>
          ))}
        </div>
      </section>
    </noscript>
  </>
) : null}
