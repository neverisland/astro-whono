---
import BaseLayout from '../layouts/BaseLayout.astro';
import TagFilterHeader from './TagFilterHeader.astro';
import EssayCard from './EssayCard.astro';
import { createWithBase, getEssaySlug, type EssayEntry } from '../lib/content';
import { getTagPath, type TagSummary } from '../lib/tags';
import { getThemeSettings } from '../lib/theme-settings';
import { getListExcerpt } from '../utils/excerpt';
import { joinPageSubtitleText } from '../utils/format';

const {
  currentPage,
  currentPath,
  currentTag = null,
  items,
  nextPath = null,
  prevPath = null,
  resultCount,
  tagSummaries,
  totalPages
} = Astro.props as {
  currentPage: number;
  currentPath: string;
  currentTag?: TagSummary | null;
  items: EssayEntry[];
  nextPath?: string | null;
  prevPath?: string | null;
  resultCount: number;
  tagSummaries: TagSummary[];
  totalPages: number;
};

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const {
  settings: {
    page
  }
} = getThemeSettings();

const pageTitleText = page.essay.title || '随笔';
const pageTitleParts = [pageTitleText, currentTag ? `#${currentTag.label}` : null, currentPage > 1 ? `第 ${currentPage} 页` : null]
  .filter(Boolean);
const pageTitle = pageTitleParts.join(' · ');
const subtitleText = joinPageSubtitleText(
  page.essay.subtitle,
  currentTag ? `标签 #${currentTag.label}` : null,
  `共 ${resultCount} 篇`,
  totalPages > 1 ? `第 ${currentPage} / ${totalPages} 页` : null
);
const pageDescription = joinPageSubtitleText(
  currentTag ? `随笔标签 #${currentTag.label}` : `${pageTitleText}列表`,
  page.essay.subtitle,
  `共 ${resultCount} 篇`,
  totalPages > 1 ? `第 ${currentPage} / ${totalPages} 页` : null
) ?? `${pageTitleText}列表`;
const scopeRootPath = '/essay/';
const fallbackListId = 'essay-tag-list';
const tagOptions = tagSummaries.map((tagSummary) => ({
  ...tagSummary,
  href: withBase(currentTag?.key === tagSummary.key ? currentPath : getTagPath('essay', tagSummary.key)),
  isActive: currentTag?.key === tagSummary.key
}));
const currentTagState = currentTag
  ? {
      clearHref: withBase(scopeRootPath),
      label: currentTag.label
    }
  : null;
---

<BaseLayout title={pageTitle} description={pageDescription} bodyClass="essay-page">
  <div
    class="entry-filters"
    data-entry-filters
    data-index-url="/essay/index.json"
    data-tag-scope="essay"
    data-active-tag-key={currentTag?.key ?? undefined}
    data-active-tag-label={currentTag?.label ?? undefined}
  >
    <TagFilterHeader
      pageTitleText={pageTitleText}
      subtitleText={subtitleText}
      rssHref={withBase('/essay/rss.xml')}
      pickerHref={`#${fallbackListId}`}
      fallbackListId={fallbackListId}
      dialogTitleId="essay-tag-dialog-title"
      currentTag={currentTagState}
      tagOptions={tagOptions}
      searchAriaLabel={`搜索${pageTitleText}`}
      headerClass="page-header page-header--essay page-header--with-search"
    />
  </div>

  <div class="list">
    {items.map((entry) => (
      <EssayCard
        href={withBase(`/archive/${getEssaySlug(entry)}/`)}
        slug={getEssaySlug(entry)}
        title={entry.data.title}
        excerpt={getListExcerpt(entry)}
        date={entry.data.date}
        tag={currentTag?.label ?? entry.data.tags?.[0]}
        badge={entry.data.badge}
      />
    ))}
  </div>

  {totalPages > 1 ? (
    <nav class="pagination" aria-label={`${pageTitleText}分页`}>
      <div class="pagination__inner">
        {prevPath ? <a class="pagination__link" rel="prev" href={withBase(prevPath)}>上一页</a> : null}
        {nextPath ? (
          <a class="pagination__link pagination__link--next" rel="next" href={withBase(nextPath)}>下一页</a>
        ) : null}
      </div>
    </nav>
  ) : null}

  <script>
    import '../scripts/entry-search.ts';
  </script>
</BaseLayout>
